{
	"name": "objecs",
	"version": "0.1.0",
	"description": "ECS",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/jakeklassen/objecs.git"
	},
	"scripts": {
		"postdocs": "cp jekyll.config.yml docs/config.yml && touch docs/.nojekyll",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"prebuild": "pnpm run clean",
		"build": "pnpm run lint && tsup",
		"build:watch": "nodemon --exec 'pnpm run build || exit 1'",
		"prepublishOnly": "nr build",
		"release": "bumpp --commit --push --tag && pnpm publish",
		"test": "vp test",
		"pretest:coverage": "pnpm run clean",
		"test:coverage": "vp test run --coverage",
		"clean": "rimraf dist",
		"check-exports": "attw --pack ."
	},
	"author": "Jake Klassen <jklassendev@gmail.com>",
	"license": "MIT",
	"keywords": [
		"gamedev",
		"ecs",
		"entity component system",
		"typescript"
	],
	"devDependencies": {
		"@antfu/ni": "29.0.0",
		"@arethetypeswrong/cli": "0.18.2",
		"@types/benchmark": "^2.1.5",
		"@types/node": "^24.12.0",
		"benchmark": "^2.1.4",
		"bumpp": "10.4.1",
		"globals": "17.4.0",
		"nodemon": "^3.1.14",
		"rimraf": "^6.1.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plus": "catalog:",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	}
}

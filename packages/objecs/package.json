{
	"name": "objecs",
	"version": "0.2.0",
	"description": "ECS",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/jakeklassen/objecs.git"
	},
	"scripts": {
		"postdocs": "cp jekyll.config.yml docs/config.yml && touch docs/.nojekyll",
		"lint": "oxlint src",
		"lint:fix": "oxlint --fix src",
		"prebuild": "pnpm run clean",
		"build": "pnpm run lint && tsdown",
		"build:watch": "nodemon --exec 'pnpm run build || exit 1'",
		"prepublishOnly": "nr build",
		"release": "bumpp --commit --push --tag && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
		"test": "vitest",
		"pretest:coverage": "pnpm run clean",
		"test:coverage": "vitest run --coverage",
		"clean": "rimraf dist",
		"check-exports": "attw --pack ."
	},
	"author": "Jake Klassen <jklassendev@gmail.com>",
	"license": "MIT",
	"keywords": [
		"gamedev",
		"ecs",
		"entity component system",
		"typescript"
	],
	"devDependencies": {
		"@antfu/ni": "30.2.0",
		"@arethetypeswrong/cli": "0.18.4",
		"@types/benchmark": "^2.1.5",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"benchmark": "^2.1.4",
		"bumpp": "11.1.0",
		"globals": "17.7.0",
		"nodemon": "^3.1.14",
		"oxlint": "1.73.0",
		"oxlint-tsgolint": "0.24.0",
		"rimraf": "^6.1.3",
		"tsdown": "0.22.4",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
